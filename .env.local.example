# Copy this file to .env.local and fill in your own values from
# https://upstash.com (Redis database → REST API section).
#
# Not required for local development — if these are left unset, the app
# automatically falls back to an in-memory store. They ARE required for
# deployments that run multiple server instances (e.g. Vercel).

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
